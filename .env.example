# Copiar a ".env" en esta misma carpeta. docker compose lo lee solo
# si esta al lado del docker-compose*.yml que se este corriendo.
#
# En la instancia de api-server hace falta la IP privada (o DNS interno)
# de cada instancia EC2 con un microservicio Java:
USUARIOS_HOST=
CURSOS_HOST=
NOTAS_HOST=
ASISTENCIA_HOST=
ANOTACIONES_HOST=
REUNIONES_HOST=

# En la instancia de school (nginx) hace falta la IP privada (o DNS
# interno) de la instancia EC2 donde corre api-server:
API_SERVER_HOST=
API_SERVER_PORT=8080
